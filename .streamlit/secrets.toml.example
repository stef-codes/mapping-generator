# Copy to Streamlit Community Cloud → App settings → Secrets
# (Do NOT use .env syntax here — TOML requires quotes around string values.)
#
# Local dev: copy to .streamlit/secrets.toml (gitignored) OR use .env at repo root.

GEMINI_API_KEY = "paste-your-gemini-api-key-here"
GEMINI_MODEL = "gemini-2.5-flash"
AI_BATCH_SIZE = "15"
PREVIEW_ROW_LIMIT = "500"

# Optional — only if using the Live database tab on Windows server (not Streamlit Cloud):
# DB_DEV_CONNECTION_STRING = "DRIVER={ODBC Driver 17 for SQL Server};SERVER=dev-sql.example.com;DATABASE=SourceDB;Trusted_Connection=yes;"
# DB_QA_CONNECTION_STRING = "DRIVER={ODBC Driver 17 for SQL Server};SERVER=qa-sql.example.com;DATABASE=SourceDB;Trusted_Connection=yes;"
