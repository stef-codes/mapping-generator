# Copy to .env and fill in connection strings for DEV/QA environments.
# Uses Windows (Trusted) authentication — no credentials stored in the app.

DB_DEV_CONNECTION_STRING=DRIVER={ODBC Driver 17 for SQL Server};SERVER=dev-sql.example.com;DATABASE=SourceDB;Trusted_Connection=yes;
DB_QA_CONNECTION_STRING=DRIVER={ODBC Driver 17 for SQL Server};SERVER=qa-sql.example.com;DATABASE=SourceDB;Trusted_Connection=yes;

# Gemini — optional, enables AI suggestions for rows rules cannot resolve
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AI_BATCH_SIZE=15
PREVIEW_ROW_LIMIT=500
